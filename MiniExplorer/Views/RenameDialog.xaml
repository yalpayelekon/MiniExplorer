<Window x:Class="MiniExplorer.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:MiniExplorer.Localization"
        Title="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Dialog_RenameTitle}"
        Height="160"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Background}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Foreground="{DynamicResource Brush.Foreground}" Margin="0,0,0,8"
                   Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Dialog_NewName}"/>
        <TextBox x:Name="NameBox"
                 Grid.Row="1"
                 Height="32"
                 VerticalContentAlignment="Center"
                 KeyDown="NameBox_KeyDown"/>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="90" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"
                    Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Common_OK}"/>
            <Button Width="90" IsCancel="True" Click="Cancel_Click"
                    Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Common_Cancel}"/>
        </StackPanel>
    </Grid>
</Window>
