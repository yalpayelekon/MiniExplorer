<Window x:Class="MiniExplorer.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MiniExplorer.Models"
        Title="Ayarlar"
        Width="620"
        Height="680"
        MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.Foreground}">
    <Window.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
            <Setter Property="Margin" Value="0,5,16,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Görünüm" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Uygulamanın renk paletini ve içerik ölçeğini seçin."
                                   Style="{StaticResource SectionHintStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Tema" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Dark}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#1E1E1E" BorderBrush="#666" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="Koyu"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Blue}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#162433" BorderBrush="#5BC0EB" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="Mavi"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Amoled}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#000000" BorderBrush="#00C853" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="AMOLED"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Nord}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#2E3440" BorderBrush="#88C0D0" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="Nord"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Dracula}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#282A36" BorderBrush="#BD93F9" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="Dracula"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Light}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#F5F7FA" BorderBrush="#2563EB" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="Açık"/></StackPanel>
                                </ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="İkon boyutu" Margin="0,12,0,0" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="0,12,0,0"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding IconSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="Küçük" Tag="{x:Static models:IconSizePreset.Small}"/>
                                <ComboBoxItem Content="Orta" Tag="{x:Static models:IconSizePreset.Medium}"/>
                                <ComboBoxItem Content="Büyük" Tag="{x:Static models:IconSizePreset.Large}"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Üst bölüm" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Sekme çubuğunun görünümünü ve araç düğmelerini özelleştirin."
                                   Style="{StaticResource SectionHintStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Header stili" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding HeaderStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="Varsayılan" Tag="{x:Static models:HeaderStylePreset.Default}"/>
                                <ComboBoxItem Content="Daha koyu" Tag="{x:Static models:HeaderStylePreset.Darker}"/>
                                <ComboBoxItem Content="Vurgu" Tag="{x:Static models:HeaderStylePreset.Accent}"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="Yoğunluk" Margin="0,12,0,0" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="0,12,0,0"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding HeaderDensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="Kompakt" Tag="{x:Static models:HeaderDensityPreset.Compact}"/>
                                <ComboBoxItem Content="Normal" Tag="{x:Static models:HeaderDensityPreset.Normal}"/>
                                <ComboBoxItem Content="Geniş" Tag="{x:Static models:HeaderDensityPreset.Spacious}"/>
                            </ComboBox>
                        </Grid>

                        <Separator Margin="0,18,0,12"/>
                        <TextBlock Text="Araç çubuğu düğmeleri"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <UniformGrid Columns="2">
                            <CheckBox Content="Geri" IsChecked="{Binding ShowBackButton, Mode=TwoWay}"/>
                            <CheckBox Content="İleri" IsChecked="{Binding ShowForwardButton, Mode=TwoWay}"/>
                            <CheckBox Content="Yukarı" IsChecked="{Binding ShowUpButton, Mode=TwoWay}"/>
                            <CheckBox Content="Yenile" IsChecked="{Binding ShowRefreshButton, Mode=TwoWay}"/>
                            <CheckBox Content="Yolu kopyala" IsChecked="{Binding ShowCopyPathButton, Mode=TwoWay}"/>
                            <CheckBox Content="Explorer'da aç" IsChecked="{Binding ShowExplorerButton, Mode=TwoWay}"/>
                        </UniformGrid>
                        <TextBlock Text="Ayarlar düğmesi her zaman görünür kalır."
                                   Foreground="{DynamicResource Brush.ForegroundMuted}"
                                   FontSize="12"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="1"
                Content="Kapat"
                Width="110"
                HorizontalAlignment="Right"
                Margin="0,4,8,0"
                IsCancel="True"/>
    </Grid>
</Window>
