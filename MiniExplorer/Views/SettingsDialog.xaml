<Window x:Class="MiniExplorer.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MiniExplorer.Models"
        xmlns:loc="clr-namespace:MiniExplorer.Localization"
        Title="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_Title}"
        Width="620"
        Height="720"
        MinHeight="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        Foreground="{DynamicResource Brush.Foreground}">
    <Window.Resources>
        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
            <Setter Property="Margin" Value="0,5,16,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,8,0">
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_Appearance}"/>
                        <TextBlock Style="{StaticResource SectionHintStyle}"
                                   Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_AppearanceHint}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_Theme}" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Dark}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#1E1E1E" BorderBrush="#666" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ThemeDark}"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Blue}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#162433" BorderBrush="#5BC0EB" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ThemeBlue}"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Amoled}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#000000" BorderBrush="#00C853" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ThemeAmoled}"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Nord}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#2E3440" BorderBrush="#88C0D0" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ThemeNord}"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Dracula}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#282A36" BorderBrush="#BD93F9" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ThemeDracula}"/></StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="{x:Static models:ThemePreset.Light}">
                                    <StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="3" Background="#F5F7FA" BorderBrush="#2563EB" BorderThickness="1" Margin="0,0,8,0"/><TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ThemeLight}"/></StackPanel>
                                </ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Center"
                                       Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_Language}"/>
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="0,12,0,0"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding Language, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Tag="{x:Static models:LanguagePreset.Turkish}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_LanguageTurkish}"/>
                                <ComboBoxItem Tag="{x:Static models:LanguagePreset.English}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_LanguageEnglish}"/>
                            </ComboBox>

                            <TextBlock Grid.Row="2" Margin="0,12,0,0" VerticalAlignment="Center"
                                       Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_IconSize}"/>
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      Margin="0,12,0,0"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding IconSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Tag="{x:Static models:IconSizePreset.Small}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_IconSmall}"/>
                                <ComboBoxItem Tag="{x:Static models:IconSizePreset.Medium}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_IconMedium}"/>
                                <ComboBoxItem Tag="{x:Static models:IconSizePreset.Large}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_IconLarge}"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_HeaderSection}"/>
                        <TextBlock Style="{StaticResource SectionHintStyle}"
                                   Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_HeaderHint}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_HeaderStyle}"/>
                            <ComboBox Grid.Column="1"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding HeaderStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Tag="{x:Static models:HeaderStylePreset.Default}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_HeaderDefault}"/>
                                <ComboBoxItem Tag="{x:Static models:HeaderStylePreset.Darker}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_HeaderDarker}"/>
                                <ComboBoxItem Tag="{x:Static models:HeaderStylePreset.Accent}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_HeaderAccent}"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Margin="0,12,0,0" VerticalAlignment="Center"
                                       Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_Density}"/>
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="0,12,0,0"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding HeaderDensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Tag="{x:Static models:HeaderDensityPreset.Compact}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_DensityCompact}"/>
                                <ComboBoxItem Tag="{x:Static models:HeaderDensityPreset.Normal}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_DensityNormal}"/>
                                <ComboBoxItem Tag="{x:Static models:HeaderDensityPreset.Spacious}"
                                              Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_DensitySpacious}"/>
                            </ComboBox>
                        </Grid>

                        <Separator Margin="0,18,0,12"/>
                        <TextBlock FontWeight="SemiBold" Margin="0,0,0,6"
                                   Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ToolbarButtons}"/>
                        <UniformGrid Columns="2">
                            <CheckBox IsChecked="{Binding ShowBackButton, Mode=TwoWay}"
                                      Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ShowBack}"/>
                            <CheckBox IsChecked="{Binding ShowForwardButton, Mode=TwoWay}"
                                      Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ShowForward}"/>
                            <CheckBox IsChecked="{Binding ShowUpButton, Mode=TwoWay}"
                                      Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ShowUp}"/>
                            <CheckBox IsChecked="{Binding ShowRefreshButton, Mode=TwoWay}"
                                      Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ShowRefresh}"/>
                            <CheckBox IsChecked="{Binding ShowCopyPathButton, Mode=TwoWay}"
                                      Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ShowCopyPath}"/>
                            <CheckBox IsChecked="{Binding ShowExplorerButton, Mode=TwoWay}"
                                      Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_ShowExplorer}"/>
                        </UniformGrid>
                        <TextBlock Foreground="{DynamicResource Brush.ForegroundMuted}"
                                   FontSize="12"
                                   Margin="0,8,0,0"
                                   Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Settings_SettingsAlwaysVisible}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="1"
                Width="110"
                HorizontalAlignment="Right"
                Margin="0,4,8,0"
                IsCancel="True"
                Content="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Common_Close}"/>
    </Grid>
</Window>
