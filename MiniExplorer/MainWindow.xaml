<Window x:Class="MiniExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MiniExplorer.Models"
        xmlns:vm="clr-namespace:MiniExplorer.ViewModels"
        xmlns:loc="clr-namespace:MiniExplorer.Localization"
        Title="Mini Explorer"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="720"
        Width="1180"
        MinHeight="480"
        MinWidth="800"
        PreviewKeyDown="Window_PreviewKeyDown"
        DpiChanged="Window_DpiChanged"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}"/>
                    <Setter Property="Padding" Value="12,10,12,4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="{Binding DataContext.ToolbarControlSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Height" Value="{Binding DataContext.ToolbarControlSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.HeaderFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.HeaderButton}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.HeaderForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.HeaderButtonHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="{Binding DataContext.ToolbarControlSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="FontSize" Value="{Binding DataContext.HeaderFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.HeaderInput}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.HeaderForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarFilterTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ToolbarTextBoxStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,8,10,8"/>
        </Style>

        <Style x:Key="ToolbarFilterHostStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="{Binding DataContext.ToolbarControlSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.HeaderInput}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.HeaderBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style x:Key="SidebarFooterButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Brush.HeaderBackground}"
                BorderBrush="{DynamicResource Brush.HeaderBorder}"
                BorderThickness="0,0,0,1"
                Padding="{Binding TabBarPadding}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Content="+"
                        Margin="8,0,0,6"
                        Command="{Binding NewTabCommand}"
                        ToolTip="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Toolbar_NewTab}"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,0,0">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TabViewModel}">
                                <Border Margin="0,0,4,0"
                                        Padding="{Binding DataContext.TabItemPadding, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CornerRadius="6,6,0,0"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1,1,1,1"
                                        MouseLeftButtonUp="TabHeader_Click"
                                        Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource Brush.TabInactive}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.TabInactiveBorder}"/>
                                            <Setter Property="BorderThickness" Value="1,1,1,1"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static vm:ActiveTabConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.ActiveTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Background" Value="{DynamicResource Brush.TabActive}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.TabAccent}"/>
                                                    <Setter Property="BorderThickness" Value="1,3,1,0"/>
                                                    <Setter Property="Margin" Value="0,0,4,-1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   MaxWidth="180"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TabInactiveForeground}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{x:Static vm:ActiveTabConverter.Instance}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.ActiveTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TabActiveForeground}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Content="×"
                                                Width="{Binding DataContext.TabChromeButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Height="{Binding DataContext.TabChromeButtonSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Padding="0"
                                                FontSize="{Binding DataContext.TabCloseFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                VerticalAlignment="Center"
                                                Click="CloseTab_Click"
                                                Tag="{Binding}"
                                                ToolTip="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Toolbar_CloseTab}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TabInactiveForeground}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{x:Static vm:ActiveTabConverter.Instance}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.ActiveTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TabActiveForeground}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource Brush.HeaderSurface}"
                BorderBrush="{DynamicResource Brush.HeaderBorder}"
                BorderThickness="0,0,0,1"
                Padding="{Binding ToolbarPadding}">
            <Grid DataContext="{Binding ActiveTab}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="264"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="←"
                            Visibility="{Binding DataContext.ShowBackButton, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                            Command="{Binding DataContext.GoBackCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="→"
                            Visibility="{Binding DataContext.ShowForwardButton, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                            Command="{Binding DataContext.GoForwardCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="↑"
                            Visibility="{Binding DataContext.ShowUpButton, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                            Command="{Binding DataContext.GoUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="↻"
                            Visibility="{Binding DataContext.ShowRefreshButton, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                            Command="{Binding DataContext.RefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Toolbar_Refresh}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Content="⧉"
                            Visibility="{Binding DataContext.ShowCopyPathButton, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                            Command="{Binding DataContext.CopyCurrentPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Toolbar_CopyPath}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            FontFamily="Segoe MDL2 Assets"
                            Content="&#xE838;"
                            Visibility="{Binding DataContext.ShowExplorerButton, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                            Command="{Binding DataContext.OpenCurrentPathInExplorerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Toolbar_OpenExplorer}"/>
                </StackPanel>
                <TextBox Grid.Column="1"
                         Style="{StaticResource ToolbarTextBoxStyle}"
                         Text="{Binding AddressText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="AddressBox_KeyDown"/>
                <Border Grid.Column="2"
                        Style="{StaticResource ToolbarFilterHostStyle}"
                        Margin="10,0,0,0"
                        ToolTip="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Toolbar_Filter}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource Brush.HeaderMuted}"
                                   FontSize="{Binding DataContext.HeaderFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,6,0"
                                   IsHitTestVisible="False"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ToolbarFilterTextBoxStyle}"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn"
                                  Width="{Binding SidebarWidthGrid}"
                                  MinWidth="180"
                                  MaxWidth="420"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource Brush.Sidebar}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Bottom"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="0,1,0,0">
                        <Button Style="{StaticResource SidebarFooterButtonStyle}"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Toolbar_Settings}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Toolbar_Settings}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                    <ListBox x:Name="SidebarList"
                             ItemsSource="{Binding Sidebar.Items}"
                             ItemContainerStyle="{StaticResource SidebarItemStyle}"
                             MouseDoubleClick="SidebarList_MouseDoubleClick"
                             PreviewMouseDown="SidebarList_PreviewMouseDown"
                             ContextMenuOpening="Sidebar_ContextMenuOpening"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SidebarItem}">
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="📌"
                                               DockPanel.Dock="Right"
                                               Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWE"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"
                          DragCompleted="SidebarSplitter_DragCompleted"/>

            <Grid x:Name="FileListPanel"
                  Grid.Column="2"
                  DataContext="{Binding ActiveTab}"
                  Background="{DynamicResource Brush.Background}"
                  PreviewMouseDown="FileListPanel_PreviewMouseDown">
                <ListView x:Name="FileList"
                          ItemsSource="{Binding Items}"
                          SelectionMode="Extended"
                          MouseDoubleClick="FileList_MouseDoubleClick"
                          PreviewMouseDown="FileList_MouseDown"
                          SelectionChanged="FileList_SelectionChanged"
                          ContextMenuOpening="FileList_ContextMenuOpening"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          Visibility="{Binding DataContext.ViewMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVisibility}, ConverterParameter=List}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="320">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="NameHeader"
                                                          Content="Ad"
                                                          Tag="{x:Static models:SortField.Name}"
                                                          Click="GridViewColumnHeader_Click"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Icon}"
                                                   Width="{Binding DataContext.ListIconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Height="{Binding DataContext.ListIconSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="160" DisplayMemberBinding="{Binding ModifiedDisplay}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="ModifiedHeader"
                                                          Content="Değiştirilme"
                                                          Tag="{x:Static models:SortField.Modified}"
                                                          Click="GridViewColumnHeader_Click"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="160" DisplayMemberBinding="{Binding TypeDisplay}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="TypeHeader"
                                                          Content="Tür"
                                                          Tag="{x:Static models:SortField.Type}"
                                                          Click="GridViewColumnHeader_Click"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="100" DisplayMemberBinding="{Binding SizeDisplay}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader x:Name="SizeHeader"
                                                          Content="Boyut"
                                                          Tag="{x:Static models:SortField.Size}"
                                                          Click="GridViewColumnHeader_Click"/>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn Width="140">
                                <GridViewColumn.Header>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=ViewMode_Label}"
                                                   Foreground="{DynamicResource Brush.ForegroundMuted}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <ComboBox x:Name="ListViewModeComboBox"
                                                  MinWidth="88"
                                                  SelectionChanged="ViewModeComboBox_SelectionChanged"/>
                                    </StackPanel>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate/>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <DockPanel Visibility="{Binding DataContext.ViewMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVisibility}, ConverterParameter=Icons}">
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <GridViewColumnHeader x:Name="IconNameHeader"
                                                  Grid.Column="0"
                                                  Content="Ad"
                                                  Tag="{x:Static models:SortField.Name}"
                                                  Click="GridViewColumnHeader_Click"
                                                  HorizontalContentAlignment="Left"/>
                            <GridViewColumnHeader x:Name="IconModifiedHeader"
                                                  Grid.Column="1"
                                                  Content="Değiştirilme"
                                                  Tag="{x:Static models:SortField.Modified}"
                                                  Click="GridViewColumnHeader_Click"
                                                  HorizontalContentAlignment="Left"/>
                            <GridViewColumnHeader x:Name="IconTypeHeader"
                                                  Grid.Column="2"
                                                  Content="Tür"
                                                  Tag="{x:Static models:SortField.Type}"
                                                  Click="GridViewColumnHeader_Click"
                                                  HorizontalContentAlignment="Left"/>
                            <GridViewColumnHeader x:Name="IconSizeHeader"
                                                  Grid.Column="3"
                                                  Content="Boyut"
                                                  Tag="{x:Static models:SortField.Size}"
                                                  Click="GridViewColumnHeader_Click"
                                                  HorizontalContentAlignment="Left"/>
                            <StackPanel Grid.Column="4"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Margin="8,0,0,0">
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=ViewMode_Label}"
                                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <ComboBox x:Name="IconViewModeComboBox"
                                          MinWidth="88"
                                          SelectionChanged="ViewModeComboBox_SelectionChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListView x:Name="IconFileList"
                              ItemsSource="{Binding Items}"
                              SelectionMode="Extended"
                              BorderThickness="0"
                              Margin="8,4,8,8"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True"
                              MouseDoubleClick="FileList_MouseDoubleClick"
                              PreviewMouseDown="FileList_MouseDown"
                              SelectionChanged="FileList_SelectionChanged"
                              ContextMenuOpening="FileList_ContextMenuOpening"
                              ScrollViewer.CanContentScroll="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="Width"
                                        Value="{Binding DataContext.ThumbnailTileWidth, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Hover}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Selection}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:FileSystemEntry}">
                                <StackPanel Width="{Binding DataContext.ThumbnailContentWidth, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Border Height="{Binding DataContext.ThumbnailImageHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <TextBlock Text="···"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.ForegroundMuted}"
                                                       FontSize="18"
                                                       Visibility="{Binding IsIconViewImageReady, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            <Image Source="{Binding TileIconImage}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   MaxWidth="{Binding DataContext.TileIconDisplaySize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   MaxHeight="{Binding DataContext.TileIconDisplaySize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   SnapsToDevicePixels="True"
                                                   Margin="4"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   MaxWidth="{Binding DataContext.TileIconDisplaySize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   MaxHeight="{Binding DataContext.TileIconDisplaySize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   SnapsToDevicePixels="True"
                                                   Margin="4"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="Wrap"
                                               MaxHeight="54"
                                               FontSize="12"
                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationNotifier.Instance}, Path=Revision, Converter={StaticResource Loc}, ConverterParameter=Common_Loading}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Grid>

        <Border Grid.Row="3"
                Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock Text="{Binding GlobalStatus}"
                       Foreground="{DynamicResource Brush.Foreground}"/>
        </Border>
    </Grid>
</Window>
