<Window x:Class="MiniExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MiniExplorer.Models"
        xmlns:vm="clr-namespace:MiniExplorer.ViewModels"
        Title="Mini Explorer"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="720"
        Width="1180"
        MinHeight="480"
        MinWidth="800"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="{StaticResource Brush.ForegroundMuted}"/>
                    <Setter Property="Padding" Value="12,10,12,4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style x:Key="ToolbarTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Brush.TabBar}"
                BorderBrush="{StaticResource Brush.TabInactiveBorder}"
                BorderThickness="0,0,0,1"
                Padding="8,6,8,0">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="+"
                        Width="32"
                        Margin="8,0,0,6"
                        Command="{Binding NewTabCommand}"
                        ToolTip="Yeni sekme (Ctrl+T)"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,0,0">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TabViewModel}">
                                <Border Margin="0,0,4,0"
                                        Padding="12,6,8,6"
                                        CornerRadius="6,6,0,0"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1,1,1,1"
                                        MouseLeftButtonUp="TabHeader_Click"
                                        Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource Brush.TabInactive}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Brush.TabInactiveBorder}"/>
                                            <Setter Property="BorderThickness" Value="1,1,1,1"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static vm:ActiveTabConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.ActiveTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Background" Value="{StaticResource Brush.TabActive}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.TabAccent}"/>
                                                    <Setter Property="BorderThickness" Value="1,3,1,0"/>
                                                    <Setter Property="Margin" Value="0,0,4,-1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   MaxWidth="180"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.TabInactiveForeground}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{x:Static vm:ActiveTabConverter.Instance}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.ActiveTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.TabActiveForeground}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Button Content="×"
                                                Width="22"
                                                Height="22"
                                                Padding="0"
                                                FontSize="14"
                                                VerticalAlignment="Center"
                                                Click="CloseTab_Click"
                                                Tag="{Binding}"
                                                ToolTip="Sekmeyi kapat (Ctrl+W)">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Foreground" Value="{StaticResource Brush.TabInactiveForeground}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{x:Static vm:ActiveTabConverter.Instance}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.ActiveTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Foreground" Value="{StaticResource Brush.TabActiveForeground}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <Grid DataContext="{Binding ActiveTab}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="264"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="←" Command="{Binding DataContext.GoBackCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="→" Command="{Binding DataContext.GoForwardCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="↑" Command="{Binding DataContext.GoUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="↻" Command="{Binding DataContext.RefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Yenile (F5)"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="⧉" Command="{Binding DataContext.CopyCurrentPathCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Yolu kopyala"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            FontFamily="Segoe MDL2 Assets"
                            Content="&#xE838;"
                            Command="{Binding DataContext.OpenCurrentPathInExplorerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Explorer'da aç"/>
                </StackPanel>
                <TextBox Grid.Column="1"
                         Style="{StaticResource ToolbarTextBoxStyle}"
                         Text="{Binding AddressText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="AddressBox_KeyDown"/>
                <TextBox Grid.Column="2"
                         Style="{StaticResource ToolbarTextBoxStyle}"
                         Margin="10,0,0,0"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Mevcut klasörde filtrele"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource Brush.Sidebar}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,0,1,0">
                <ListBox x:Name="SidebarList"
                         ItemsSource="{Binding Sidebar.Items}"
                         ItemContainerStyle="{StaticResource SidebarItemStyle}"
                         MouseDoubleClick="SidebarList_MouseDoubleClick"
                         PreviewMouseDown="SidebarList_PreviewMouseDown"
                         ContextMenuOpening="Sidebar_ContextMenuOpening">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:SidebarItem}">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="📌"
                                           DockPanel.Dock="Right"
                                           Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid x:Name="FileListPanel"
                  Grid.Column="1"
                  DataContext="{Binding ActiveTab}"
                  Background="{StaticResource Brush.Background}"
                  PreviewMouseDown="FileListPanel_PreviewMouseDown">
                <ListView x:Name="FileList"
                          ItemsSource="{Binding Items}"
                          SelectionMode="Extended"
                          MouseDoubleClick="FileList_MouseDoubleClick"
                          PreviewMouseDown="FileList_MouseDown"
                          SelectionChanged="FileList_SelectionChanged"
                          ContextMenuOpening="FileList_ContextMenuOpening"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          Visibility="{Binding UsePicturesLayout, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Ad" Width="320">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Değiştirilme" Width="160" DisplayMemberBinding="{Binding ModifiedDisplay}"/>
                            <GridViewColumn Header="Tür" Width="160" DisplayMemberBinding="{Binding TypeDisplay}"/>
                            <GridViewColumn Header="Boyut" Width="100" DisplayMemberBinding="{Binding SizeDisplay}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <ScrollViewer x:Name="PicturesScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              PanningMode="VerticalOnly"
                              Visibility="{Binding UsePicturesLayout, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <ListView x:Name="FolderAndFileList"
                                  ItemsSource="{Binding FolderAndFileItems}"
                                  SelectionMode="Extended"
                                  MaxHeight="280"
                                  BorderThickness="0"
                                  MouseDoubleClick="FileList_MouseDoubleClick"
                                  PreviewMouseDown="FolderAndFileList_MouseDown"
                                  PreviewMouseWheel="PicturesChildList_PreviewMouseWheel"
                                  SelectionChanged="FolderAndFileList_SelectionChanged"
                                  ContextMenuOpening="FileList_ContextMenuOpening"
                                  Visibility="{Binding HasFolderAndFileItems, Converter={StaticResource BoolToVisibility}}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Ad" Width="320">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Değiştirilme" Width="160" DisplayMemberBinding="{Binding ModifiedDisplay}"/>
                                    <GridViewColumn Header="Tür" Width="160" DisplayMemberBinding="{Binding TypeDisplay}"/>
                                    <GridViewColumn Header="Boyut" Width="100" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <ListView x:Name="ThumbnailList"
                                  ItemsSource="{Binding ImageItems}"
                                  SelectionMode="Extended"
                                  BorderThickness="0"
                                  Margin="8,4,8,8"
                                  MouseDoubleClick="FileList_MouseDoubleClick"
                                  PreviewMouseDown="ThumbnailList_MouseDown"
                                  PreviewMouseWheel="PicturesChildList_PreviewMouseWheel"
                                  SelectionChanged="ThumbnailList_SelectionChanged"
                                  ContextMenuOpening="FileList_ContextMenuOpening"
                                  ScrollViewer.CanContentScroll="False"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="4"/>
                                    <Setter Property="Width" Value="270"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Brush.Selection}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Brush.Hover}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:FileSystemEntry}">
                                    <StackPanel Width="252">
                                        <Border Height="195"
                                                Background="{StaticResource Brush.Surface}"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Margin="0,0,0,6">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   Margin="4"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="54"
                                                   FontSize="12"
                                                   Foreground="{StaticResource Brush.Foreground}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>

                <TextBlock Text="Yükleniyor..."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.ForegroundMuted}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Grid>

        <Border Grid.Row="3"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock Text="{Binding GlobalStatus}"/>
        </Border>
    </Grid>
</Window>
