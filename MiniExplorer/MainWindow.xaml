<Window x:Class="MiniExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MiniExplorer.Models"
        xmlns:vm="clr-namespace:MiniExplorer.ViewModels"
        Title="Mini Explorer"
        Height="720"
        Width="1180"
        MinHeight="480"
        MinWidth="800"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="{StaticResource Brush.ForegroundMuted}"/>
                    <Setter Property="Padding" Value="12,10,12,4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="+"
                        Width="32"
                        Margin="8,0,0,0"
                        Command="{Binding NewTabCommand}"
                        ToolTip="Yeni sekme (Ctrl+T)"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TabViewModel}">
                                <Border Margin="0,0,4,0"
                                        Padding="10,4"
                                        CornerRadius="4"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        MouseLeftButtonUp="TabHeader_Click"
                                        Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource Brush.Background}"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static vm:ActiveTabConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.ActiveTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Background" Value="{StaticResource Brush.Selection}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <Button Content="×"
                                                Width="22"
                                                Padding="0"
                                                Click="CloseTab_Click"
                                                Tag="{Binding}"
                                                ToolTip="Sekmeyi kapat (Ctrl+W)"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid DataContext="{Binding ActiveTab}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="←" Width="32" Margin="0,0,4,0" Command="{Binding DataContext.GoBackCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="→" Width="32" Margin="0,0,4,0" Command="{Binding DataContext.GoForwardCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="↑" Width="32" Margin="0,0,4,0" Command="{Binding DataContext.GoUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="↻" Width="32" Command="{Binding DataContext.RefreshCommand, RelativeSource={RelativeSource AncestorType=Window}}" ToolTip="Yenile (F5)"/>
                </StackPanel>
                <TextBox Grid.Column="1"
                         Text="{Binding AddressText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="AddressBox_KeyDown"/>
                <TextBox Grid.Column="2"
                         Margin="8,0,0,0"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Mevcut klasörde filtrele"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource Brush.Sidebar}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,0,1,0">
                <ListBox x:Name="SidebarList"
                         ItemsSource="{Binding Sidebar.Items}"
                         ItemContainerStyle="{StaticResource SidebarItemStyle}"
                         MouseDoubleClick="SidebarList_MouseDoubleClick"
                         PreviewMouseDown="SidebarList_PreviewMouseDown"
                         ContextMenuOpening="Sidebar_ContextMenuOpening">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:SidebarItem}">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="📌"
                                           DockPanel.Dock="Right"
                                           Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid x:Name="FileListPanel"
                  Grid.Column="1"
                  DataContext="{Binding ActiveTab}"
                  Background="{StaticResource Brush.Background}"
                  PreviewMouseDown="FileListPanel_PreviewMouseDown">
                <ListView x:Name="FileList"
                          ItemsSource="{Binding Items}"
                          SelectionMode="Extended"
                          MouseDoubleClick="FileList_MouseDoubleClick"
                          PreviewMouseDown="FileList_MouseDown"
                          SelectionChanged="FileList_SelectionChanged"
                          ContextMenuOpening="FileList_ContextMenuOpening"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Ad" Width="320">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Değiştirilme" Width="160" DisplayMemberBinding="{Binding ModifiedDisplay}"/>
                            <GridViewColumn Header="Tür" Width="160" DisplayMemberBinding="{Binding TypeDisplay}"/>
                            <GridViewColumn Header="Boyut" Width="100" DisplayMemberBinding="{Binding SizeDisplay}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <TextBlock Text="Yükleniyor..."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.ForegroundMuted}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Grid>

        <Border Grid.Row="3"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock Text="{Binding GlobalStatus}"/>
        </Border>
    </Grid>
</Window>
